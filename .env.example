# Database Configuration
# Set your secure password here
MSSQL_SA_PASSWORD=YourSecurePassword123!

# Docker Platform Configuration
# For Apple Silicon Macs (M1/M2/M3): use linux/arm64
# For Intel Macs or Windows: use linux/amd64
# Leave empty to auto-detect (defaults to linux/arm64)
DOCKER_PLATFORM=linux/arm64

# SQL Server Port (change if 1433 is already in use)
SQL_SERVER_PORT=1433

# Backend Configuration
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# Database Connection String
# Windows: Use ODBC+Driver+18+for+SQL+Server (requires ODBC Driver installation)
# Mac: Use ODBC+Driver+18+for+SQL+Server (install via: brew install msodbcsql18)
# Alternative: Use pymssql (cross-platform, no driver needed): mssql+pymssql://...
# Postgres (Default for Docker): postgresql+psycopg2://postgres:postgres@postgres:5432/todoDB
# DATABASE_URL=mssql+pyodbc://sa:YourSecurePassword123!@localhost:1433/todo_db?driver=ODBC+Driver+18+for+SQL+Server&TrustServerCertificate=yes
# PostHog Configuration
POSTHOG_KEY=phc_your_key_here
POSTHOG_HOST=https://us.i.posthog.com