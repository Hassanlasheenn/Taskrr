# Production Environment Template
# Copy this file to .env.prod and fill in the real values
ENVIRONMENT=production

# Security Keys
SECRET_KEY=your_secure_random_string_here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Database Configuration
POSTGRES_USER=hassan_admin
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=taskhub_production

# PostHog Configuration (Analytics)
POSTHOG_KEY=phc_TB8vPisLSvBxqEoCsz02yYTB1MGoHDERZW5lnONcrv4
POSTHOG_HOST=https://us.i.posthog.com

# Database URL for Backend
DATABASE_URL=postgresql+psycopg2://hassan_admin:your_secure_password_here@postgres:5432/taskhub_production

# AWS S3 Configuration
AWS_ACCESS_KEY_ID=your_access_key_id
AWS_SECRET_ACCESS_KEY=your_secret_access_key
AWS_S3_BUCKET_NAME=your_bucket_name
AWS_S3_REGION=eu-north-1
